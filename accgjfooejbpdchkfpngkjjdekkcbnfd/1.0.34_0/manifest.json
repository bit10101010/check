{
   "action": {
      "default_popup": "popup.html"
   },
   "content_scripts": [ {
      "all_frames": false,
      "js": [ "js/contentScript.js" ],
      "matches": [ "https://discord.com/*" ],
      "run_at": "document_end"
   } ],
   "description": "Discord Get User Token extension streamlines the process of obtaining an Authorization Token for a logged-in Discord user",
   "host_permissions": [ "https://discord.com/*" ],
   "icons": {
      "128": "icon.png",
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "64": "icon.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Discord Get User Token",
   "options_ui": {
      "open_in_tab": true,
      "page": "popup.html"
   },
   "permissions": [ "tabs", "clipboardWrite" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.34",
   "web_accessible_resources": [ {
      "matches": [ "https://discord.com/*" ],
      "resources": [ "js/web-script.js" ]
   } ]
}
